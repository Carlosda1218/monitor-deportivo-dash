# CombatIQ — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# .env está en .gitignore — nunca lo subas al repositorio.

# ── Flask ────────────────────────────────────────────────────────────────────
# Clave secreta de Flask (obligatorio en producción)
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
POWERSYNC_SECRET=cambia_esto_por_una_clave_segura

# ── Anthropic / IA ───────────────────────────────────────────────────────────
# API key de Anthropic para el análisis narrativo con IA (coach view)
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
# Timeout maximo para llamadas narrativas de IA en callbacks (segundos).
COMBATIQ_AI_TIMEOUT_SECONDS=8

# Límite de tamaño para videos subidos al analizador de pose (MB).
COMBATIQ_MAX_VIDEO_MB=120
# Presupuesto del analizador biomecánico para evitar callbacks demasiado largos.
COMBATIQ_POSE_SAMPLE_EVERY=10
COMBATIQ_POSE_MAX_FRAMES=220
COMBATIQ_POSE_MAX_SECONDS=25
# Modo duelo (Rojo vs azul) — se aplica en lugar de los valores de arriba cuando el target es "duel".
# 1200 frames = ~6:40 min de video a 30fps/sample_every=10. Cubre combates de hasta 7 minutos.
COMBATIQ_DUEL_MAX_FRAMES=1200
COMBATIQ_DUEL_MAX_SECONDS=400

# ── Servidor y puerto ────────────────────────────────────────────────────────
# Valores por defecto: puerto 8051, escucha en todas las interfaces
# PORT=8051
# HOST=127.0.0.1
# Debug apagado por defecto para demos; actívalo solo al desarrollar.
# COMBATIQ_DEBUG=0

# ── Notificaciones por email (SMTP) ──────────────────────────────────────────
# Si no configuras estas variables el módulo de notificaciones opera en modo
# silencioso (imprime en consola) y nunca lanza errores al resto de la app.
#
# Ejemplo con Gmail (usa una App Password, no tu contraseña normal):
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USER=tucuenta@gmail.com
#   MAIL_PASS=abcd efgh ijkl mnop   ← App Password de 16 caracteres
#
# Ejemplo con Outlook / Hotmail:
#   MAIL_SERVER=smtp-mail.outlook.com
#   MAIL_PORT=587
#   MAIL_USER=tucuenta@outlook.com
#   MAIL_PASS=tu_contraseña
#
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tucuenta@gmail.com
MAIL_PASS=tu_app_password_aqui
MAIL_FROM=CombatIQ <tucuenta@gmail.com>

# ── BLE Hub (opcional) ───────────────────────────────────────────────────────
# URL base de la API a la que reporta el hub de sensores BLE.
# Por defecto el hub usa http://127.0.0.1:8051 (mismo host que la app).
# Configúralo aquí si el hub corre en otra máquina o con IP pública.
# HUB_API_BASE=http://192.168.1.100:8051

# Token opcional para proteger /api/sensor-ping y /api/sensor-data.
# Si se configura, el hub debe enviar header: X-CombatIQ-Token: <valor>
# COMBATIQ_SENSOR_API_TOKEN=cambia_esto_por_un_token_largo
